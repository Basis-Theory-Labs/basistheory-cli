{
  "name": "@basis-theory-labs/cli",
  "version": "4.0.0",
  "description": "Basis Theory CLI tool",
  "author": "Davi Aquino @djejaquino",
  "bin": {
    "bt": "./bin/run"
  },
  "homepage": "https://github.com/Basis-Theory-Labs/basistheory-cli",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": "Basis-Theory-Labs/basistheory-cli",
  "files": [
    "/bin",
    "/dist",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@basis-theory/node-sdk": "^5.2.0",
    "@inquirer/checkbox": "^1.5.0",
    "@inquirer/confirm": "^2.0.15",
    "@inquirer/input": "^1.2.14",
    "@inquirer/select": "^1.3.1",
    "@oclif/core": "^2",
    "@oclif/plugin-help": "^5",
    "@oclif/plugin-plugins": "^2.4.7",
    "cloudflared": "^0.7.0",
    "debug": "^4.3.4",
    "detect-port": "^1.5.1",
    "dotenv": "^16.3.1",
    "lodash.debounce": "^4.0.8",
    "lodash.groupby": "^4.6.0",
    "pino": "^8.14.1",
    "pino-pretty": "^10.0.0",
    "serialize-error": "^11.0.0",
    "socket.io": "^4.7.1"
  },
  "devDependencies": {
    "@basis-theory/eslint-config": "^1.2.0",
    "@oclif/test": "^2.3.22",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.0.3",
    "@semantic-release/npm": "^10.0.4",
    "@semantic-release/release-notes-generator": "^11.0.3",
    "@types/chai": "^4",
    "@types/debug": "^4.1.8",
    "@types/detect-port": "^1.3.3",
    "@types/lodash.debounce": "^4.0.7",
    "@types/lodash.groupby": "^4.6.9",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.18.36",
    "@types/sinon": "^21.0.0",
    "chai": "^4",
    "eslint": "^7.32.0",
    "eslint-config-oclif": "^4",
    "eslint-config-oclif-typescript": "^1.0.3",
    "mocha": "^9.2.2",
    "oclif": "^3",
    "prettier": "^2.8.8",
    "semantic-release": "^21.0.5",
    "shx": "^0.3.3",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.1",
    "tslib": "^2.5.3",
    "typescript": "^4.9.5"
  },
  "oclif": {
    "bin": "bt",
    "dirname": "bt",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "plugins": [],
    "topicSeparator": " ",
    "topics": {
      "proxies": {
        "description": "Manage Proxies"
      },
      "reactors": {
        "description": "Manage Reactors"
      },
      "tenants": {
        "description": "Manage Tenants"
      },
      "tenants members": {
        "description": "Manage Tenant Members"
      },
      "tenants invitations": {
        "description": "Manage Tenant Invitations"
      },
      "tenants merchants": {
        "description": "View Tenant Merchants"
      },
      "logs": {
        "description": "View Audit Logs"
      },
      "webhooks": {
        "description": "Manage Webhooks"
      },
      "keys": {
        "description": "Manage Client Encryption Keys"
      },
      "tokens": {
        "description": "Manage Tokens"
      },
      "token-intents": {
        "description": "Manage Token Intents"
      },
      "documents": {
        "description": "Manage Documents"
      },
      "apple-pay": {
        "description": "[Beta] Manage Apple Pay"
      },
      "apple-pay domains": {
        "description": "[Beta] Manage Apple Pay Domains"
      },
      "apple-pay merchants": {
        "description": "[Beta] Manage Apple Pay Merchants"
      },
      "apple-pay merchants certificates": {
        "description": "[Beta] Manage Apple Pay Merchant Certificates"
      },
      "google-pay": {
        "description": "[Beta] Manage Google Pay"
      },
      "google-pay merchants": {
        "description": "[Beta] Manage Google Pay Merchants"
      },
      "google-pay merchants certificates": {
        "description": "[Beta] Manage Google Pay Merchant Certificates"
      },
      "account-updater": {
        "description": "Account Updater Operations"
      },
      "account-updater jobs": {
        "description": "Manage Account Updater Batch Jobs"
      },
      "network-tokens": {
        "description": "[Beta] Manage Network Tokens"
      },
      "3ds": {
        "description": "[Beta] 3D Secure Operations"
      },
      "3ds sessions": {
        "description": "[Beta] Manage 3DS Sessions"
      },
      "enrichments": {
        "description": "[Beta] Data Enrichment Operations"
      },
      "connections": {
        "description": "Manage Connections"
      },
      "connections stripe-forward": {
        "description": "Stripe Forward Connection"
      }
    }
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint . --ext .ts --config .eslintrc",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "yarn build && oclif manifest && oclif readme",
    "version": "yarn build && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "release": "semantic-release"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "bugs": "https://github.com/Basis-Theory-Labs/basistheory-cli/issues",
  "keywords": [
    "basis",
    "theory",
    "cli",
    "logs"
  ],
  "types": "dist/index.d.ts",
  "prettier": "@basis-theory/eslint-config/prettier",
  "publishConfig": {
    "access": "public"
  }
}
